# Токен вашого Telegram бота (отриманий від @BotFather)
BOT_TOKEN=your_bot_token_here

# Ваш особистий Telegram ID (щоб бот знав, що ви адмін і міг надсилати вам дані та меню вибору)
ADMIN_ID=123456789

# Telegram ID чату з постачальником кодів (це може бути приватний чат з ним або ID групи)
# Для груп ID зазвичай починається з -100 (наприклад: -100987654321)
GIVER_CHAT_ID=987654321

# Шлях до бази даних SQLite
DB_FILE=bot.db

# Telegram ID чату для надсилання готових анкет (якщо не вказано, надсилається адміну)
ANKETA_CHAT_ID=

# API-ключ для доступу до сервісу OpenRouter (Gemini або інші моделі)
OPENROUTER_API_KEY=

# Назва ШІ моделі на OpenRouter (наприклад: google/gemini-2.5-pro or google/gemini-2.5-flash)
OPENROUTER_MODEL=google/gemini-2.5-pro

# Токен додаткового бота для логування системних помилок та повідомлень (необов'язково)
LOG_BOT_TOKEN=

# Облікові дані для входу в адмін-панель (Basic Auth). Якщо порожні, авторизація вимкнена.
WEB_USERNAME=admin
WEB_PASSWORD=secure_password_here
